<UserControl
    x:Class="CloudSpritzers1.src.view.message.MessageView"
    xmlns:local="using:CloudSpritzers1.src.view.message"
    x:DataType="local:MessageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:dto="using:CloudSpritzers1.src.dto"
    xmlns:conv="using:CloudSpritzers1.src.converter"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:DateTimeToLocalConverter x:Key="DateConverter"/>
        <conv:BooleanToAlignmentConverter x:Key="AlignConverter"/>
    </UserControl.Resources>
    <Border x:Name="BubbleBorder"
            Style="{StaticResource CardStyle}"
            MaxWidth="400"
            HorizontalAlignment="{x:Bind DataTransferObjectContainingMessageDetailsForViewModelBinding.IsOutgoing, Converter={StaticResource AlignConverter}, Mode=OneWay}"
            BorderBrush="{ThemeResource BorderBrush}"
            BorderThickness="1">
        <StackPanel>
            <TextBlock x:Name="SenderLabel"
                       Text="{x:Bind DataTransferObjectContainingMessageDetailsForViewModelBinding.SenderName}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryBrush}"
                       Visibility="Visible" />
            <TextBlock x:Name="MessageTextBlock"
                       Text="{x:Bind DataTransferObjectContainingMessageDetailsForViewModelBinding.MessageText}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource PrimaryTextColor}"
                       Margin="0,4" />
            <TextBlock x:Name="TimestampLabel"
                       Text="{x:Bind DataTransferObjectContainingMessageDetailsForViewModelBinding.Timestamp, Converter={StaticResource DateConverter}, Mode=OneWay}"
                       Style="{StaticResource SubtitleTextStyle}"
                       FontSize="10"
                       Margin="0,5,0,0"
                       HorizontalAlignment="Right"/>
        </StackPanel>
    </Border>


</UserControl>