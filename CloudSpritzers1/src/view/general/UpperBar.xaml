<UserControl
    x:Class="CloudSpritzers1.src.view.general.UpperBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:CloudSpritzers1.src.converter"
    mc:Ignorable="d"
    VerticalAlignment="Top">

    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="{ThemeResource CardBackgroundBrush}" 
      Padding="20,5" 
      Height="70" 
      BorderBrush="{ThemeResource BorderBrush}" 
      BorderThickness="0,0,0,1">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Button Click="OnLandingRequested">
            <Button.Resources>
                <SolidColorBrush x:Key="ButtonBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource PageBackgroundColor}"/>
                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource PrimaryMutedColor}"/>
                <SolidColorBrush x:Key="ButtonBackgroundFocused" Color="Transparent"/>
            </Button.Resources>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="ms-appx:///Assets/CloudSpritzersLogo.png" Width="70" Height="70"/>
                <TextBlock Text="CloudSpritzers" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   Foreground="{ThemeResource PrimaryBrush}"
                   Margin="10,0,0,0" 
                   VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="30">
            <Button Style="{StaticResource TextBlockButtonStyle}" Foreground="{ThemeResource PrimaryTextBrush}" Click="OnChatRequested"
                   Visibility="{Binding IsClientView, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8BD;" FontSize="16" Foreground="{ThemeResource PrimaryBrush}"/>
                    <TextBlock Text="Chat" VerticalAlignment="Center" Foreground="{ThemeResource PrimaryTextBrush}"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource TextBlockButtonStyle}" Foreground="{ThemeResource PrimaryTextBrush}" Click="OnFAQRequested">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE11B;" FontSize="16" Foreground="{ThemeResource PrimaryBrush}"/>
                    <TextBlock Text="FAQ" VerticalAlignment="Center" Foreground="{ThemeResource PrimaryTextBrush}"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource TextBlockButtonStyle}" Foreground="{ThemeResource PrimaryTextBrush}" Click="OnTicketsRequested">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8A1;" FontSize="16" Foreground="{ThemeResource PrimaryBrush}"/>
                    <TextBlock Text="Tickets" VerticalAlignment="Center" Foreground="{ThemeResource PrimaryTextBrush}"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource TextBlockButtonStyle}" Foreground="{ThemeResource PrimaryTextBrush}" Click="OnReviewsRequested">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE734;" FontSize="16" Foreground="{ThemeResource PrimaryBrush}"/>
                    <TextBlock Text="Reviews" VerticalAlignment="Center" Foreground="{ThemeResource PrimaryTextBrush}"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource TextBlockButtonStyle}" 
        Foreground="{ThemeResource PrimaryTextBrush}" 
        Click="OnHomeRequested">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE80F;" FontSize="16" Foreground="{ThemeResource PrimaryBrush}"/>
                    <TextBlock Text="Home" VerticalAlignment="Center" Foreground="{ThemeResource PrimaryTextBrush}"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <Button Grid.Column="4" 
            Padding="5"
            Style="{StaticResource TextBlockButtonStyle}" 
            VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid HorizontalAlignment="Center" Margin="0,0,0,2">
                    <Ellipse Width="34" Height="34" Fill="{ThemeResource PrimaryMutedBrush}"/>
                    <FontIcon Glyph="&#xE77B;" FontSize="18" Foreground="{ThemeResource PrimaryBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
                <TextBlock Text="{Binding UserDisplayLabel}"
                       FontSize="9" 
                       Foreground="{ThemeResource SecondaryTextBrush}" 
                       HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
