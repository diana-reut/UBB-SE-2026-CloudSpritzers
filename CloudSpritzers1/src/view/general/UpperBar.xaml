<UserControl
    x:Class="CloudSpritzers1.src.view.general.UpperBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:CloudSpritzers1.src.converter"
    mc:Ignorable="d"
    VerticalAlignment="Top">

    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="White" 
      Padding="20,5" 
      Height="70" 
      BorderBrush="{ThemeResource CardBackgroundBrush}" 
      BorderThickness="0,0,0,1">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Button Click="NavigateToLanding">
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="ms-appx:///Assets/CloudSpritzersLogo.png" Width="70" Height="70"/>
                <TextBlock Text="CloudSpritzers" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   Foreground="{ThemeResource NavyBrush}"
                   Margin="10,0,0,0" 
                   VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="30">
            <Button Style="{StaticResource TextBlockButtonStyle}" Foreground="{ThemeResource Navybrush}" Click="NavigateToChat"
                   Visibility="{x:Bind ViewModel.IsEmployee, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8BD;" FontSize="16"/>
                    <TextBlock Text="Chat" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource TextBlockButtonStyle}" Foreground="{ThemeResource NavyBrush}" Click="NavigateToFAQ">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE11B;" FontSize="16"/>
                    <TextBlock Text="FAQ" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource TextBlockButtonStyle}" Foreground="{ThemeResource NavyBrush}" Click="NavigateToTickets">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8A1;" FontSize="16"/>
                    <TextBlock Text="Tickets" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource TextBlockButtonStyle}" Foreground="{ThemeResource NavyBrush}" Click="NavigateToReviews">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE734;" FontSize="16"/>
                    <TextBlock Text="Reviews" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <Button Grid.Column="4" 
            Padding="5"
            Style="{StaticResource TextBlockButtonStyle}" 
            VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid HorizontalAlignment="Center" Margin="0,0,0,2">
                    <Ellipse Width="34" Height="34" Fill="{ThemeResource CardBackgroundBrush}"/>
                    <FontIcon Glyph="&#xE77B;" FontSize="18" Foreground="{ThemeResource NavyBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
                <TextBlock Text="{Binding UserId}"
                       FontSize="9" 
                       Foreground="Gray" 
                       HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>
    </Grid>
</UserControl>