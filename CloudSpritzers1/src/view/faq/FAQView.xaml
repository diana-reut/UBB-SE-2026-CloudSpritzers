<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CloudSpritzers1.Src.View.Faq.FAQView"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CloudSpritzers1.Src.Converter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:general="using:CloudSpritzers1.Src.View.General"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:dto="using:CloudSpritzers1.Src.Dto"
    mc:Ignorable="d"
    RequestedTheme="Light"
    Background="{ThemeResource CardBackgroundBrush}">

    <Page.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:BooleanToGlyphConverter x:Key="BooleanToGlyphConverter"/>
        <local:HelpfulBackgroundConverter x:Key="HelpfulBackgroundConverter"/>
        <local:HelpfulForegroundConverter x:Key="HelpfulForegroundConverter"/>
        <local:HelpfulBorderConverter x:Key="HelpfulBorderConverter"/>
        <local:NotHelpfulBackgroundConverter x:Key="NotHelpfulBackgroundConverter"/>
        <local:NotHelpfulForegroundConverter x:Key="NotHelpfulForegroundConverter"/>
        <local:NotHelpfulBorderConverter x:Key="NotHelpfulBorderConverter"/>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>

        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="SelectedCategoryButtonStyle" TargetType="Button" BasedOn="{StaticResource CategoryButtonStyle}">
            <Setter Property="Background" Value="{ThemeResource PrimaryLightBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="PopularQuestionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource PrimaryLightBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,11"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="52"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="FaqAccordionHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <general:UpperBar Grid.Row="0" />

        <Grid Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Padding="10">
                    <Border MaxWidth="1050"
                    HorizontalAlignment="Center"
                    Background="{ThemeResource CardBackgroundBrush}"
                    BorderBrush="{ThemeResource PrimaryMutedBrush}"
                    BorderThickness="1"
                    CornerRadius="4">

                        <StackPanel Spacing="16">
                            <StackPanel HorizontalAlignment="Center" Spacing="4" Margin="0,8,0,0">
                                <TextBlock Text="Frequently Asked Questions" FontSize="22" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Find quick answers to common questions" FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <Border Margin="8,0,8,0" CornerRadius="6" Padding="14">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{ThemeResource PrimaryColor}" Offset="0"/>
                                        <GradientStop Color="{ThemeResource PrimaryTextColor}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Spacing="12">
                                    <TextBlock Text="↗ Popular Questions" FontSize="15" Foreground="White" FontWeight="SemiBold"/>
                                    <ItemsControl ItemsSource="{Binding FilteredFAQs}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="2"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="dto:FAQEntryDTO">
                                                <Button Style="{StaticResource PopularQuestionButtonStyle}" Click="OpenFaqButton_Click" Width="280" Margin="0,0,24,18">
                                                    <Grid ColumnSpacing="10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Question}" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" MaxLines="2" FontSize="17" FontWeight="SemiBold" Foreground="White"/>
                                                        <Border Grid.Column="1" Background="{ThemeResource PrimaryMutedBrush}" CornerRadius="10" Padding="8,4" VerticalAlignment="Top">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <FontIcon Glyph="&#xE8A7;" FontSize="11" Foreground="White"/>
                                                                <TextBlock Text="{Binding ViewCount}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Background="{ThemeResource PageBackgroundBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,1,0,1" Padding="10">
                                <StackPanel Spacing="10">
                                    <TextBox
                                        PlaceholderText="Search FAQs by question/ answer..."
                                        Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        />
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled">
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="AllQuestionsButton" Content="All Questions" 
                                                    Style="{StaticResource SelectedCategoryButtonStyle}" Click="AllQuestionsButton_Click"/>
                                            <Button x:Name="CheckInButton" Content="Check-in Procedures" Style="{StaticResource CategoryButtonStyle}" Click="CheckInButton_Click"/>
                                            <Button x:Name="ParkingButton" Content="Parking" Style="{StaticResource CategoryButtonStyle}" Click="ParkingButton_Click"/>
                                            <Button x:Name="BaggageButton" Content="Baggage" Style="{StaticResource CategoryButtonStyle}" Click="BaggageButton_Click"/>
                                            <Button x:Name="TicketsButton" Content="Tickets" Style="{StaticResource CategoryButtonStyle}" Click="TicketButton_Click"/>
                                            <Button x:Name="FacilitiesButton" Content="Facilities" Style="{StaticResource CategoryButtonStyle}" Click="FacilitiesButton_Click"/>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <StackPanel x:Name="EmployeeActionsPanel" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Visibility="Collapsed">
                                        <Button x:Name="AddFaqButton" Content="Add FAQ" Click="AddFaqButton_Click" Style="{StaticResource SelectedCategoryButtonStyle}"/>
                                        <Button x:Name="EditFaqButton" Content="Edit FAQ" Click="EditFaqButton_Click" Style="{StaticResource CategoryButtonStyle}"/>
                                        <Button x:Name="DeleteFaqButton" Content="Delete FAQ" Click="DeleteFaqButton_Click" Style="{StaticResource CategoryButtonStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="8,0,8,8" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="{Binding SelectedCategory , Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                                    <ItemsControl x:Name="AllQuestionsList" ItemsSource="{Binding FilteredFAQs}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="dto:FAQEntryDTO">
                                                <Border Margin="0,0,0,12" Background="{ThemeResource CardBackgroundBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                                                    <StackPanel Spacing="10">
                                                        <Button Click="AccordionHeader_Click" Style="{StaticResource FaqAccordionHeaderButtonStyle}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Spacing="6">
                                                                    <TextBlock Text="{Binding Question}" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}" TextWrapping="Wrap"/>
                                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                                        <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{ThemeResource PrimaryBrush}"/>
                                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                                            <FontIcon Glyph="&#xE8A7;" FontSize="11" Foreground="{ThemeResource SecondaryTextBrush}"/>
                                                                            <TextBlock Text="{Binding ViewCount}" FontSize="11" Foreground="{ThemeResource SecondaryTextBrush}"/>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                                <FontIcon Grid.Column="1" Glyph="{Binding IsExpanded, Converter={StaticResource BooleanToGlyphConverter}}" Foreground="{ThemeResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Button>

                                                        <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" Spacing="12">
                                                            <TextBlock Text="{Binding Answer}" TextWrapping="Wrap" FontSize="13" Foreground="{ThemeResource PrimaryTextBrush}" LineHeight="22"/>

                                                            <StackPanel Spacing="8" Visibility="{Binding DataContext.IsAdmin, ElementName=RootPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <TextBlock Text="Feedback summary" FontSize="12" FontWeight="SemiBold"/>
                                                                <StackPanel Orientation="Horizontal" Spacing="16">
                                                                    <TextBlock Text="{Binding HelpfulVotesCount, ConverterParameter='Helpful: \{0\}'}" Foreground="#15803D" FontSize="12"/>
                                                                    <TextBlock Text="{Binding NotHelpfulVotesCount, ConverterParameter='Not helpful: \{0\}'}" Foreground="#B42318" FontSize="12"/>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <StackPanel Spacing="12" Visibility="{Binding DataContext.IsAdmin, ElementName=RootPage, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                                <TextBlock Text="Was this answer helpful?" FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}"/>
                                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                                    <Button Click="HelpfulButton_Click" Tag="{Binding}" Background="{Binding IsHelpfulSelected, Converter={StaticResource HelpfulBackgroundConverter}}" CornerRadius="8">
                                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                                            <FontIcon Glyph="&#xE00B;" FontSize="12"/>
                                                                            <TextBlock Text="Yes" FontSize="12"/>
                                                                        </StackPanel>
                                                                    </Button>
                                                                    <Button Click="NotHelpfulButton_Click" Tag="{Binding}" Background="{Binding IsNotHelpfulSelected, Converter={StaticResource NotHelpfulBackgroundConverter}}" CornerRadius="8">
                                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                                            <FontIcon Glyph="&#xE00C;" FontSize="12"/>
                                                                            <TextBlock Text="No" FontSize="12"/>
                                                                        </StackPanel>
                                                                    </Button>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>