<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CloudSpritzers1.src.view.faq.FAQAddEditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CloudSpritzers1.src.view.faq"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Background="White" Padding="24">
        <Border MaxWidth="700"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="{ThemeResource PrimaryBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="0">

            <StackPanel>
                <Border Background="{ThemeResource PrimaryVariantBrush}"
                        Height="8"
                        CornerRadius="12,12,0,0"/>

                <StackPanel Padding="24" Spacing="18">

                    <TextBlock x:Name="PageTitleText"
                                Text="Add FAQ"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource DeepTextBrush}"/>

                    <TextBlock x:Name="PageSubtitleText"
                               Text="Create a frequently asked question entry"
                               FontSize="13"
                               Foreground="{ThemeResource SecondaryTextBrush}"
                               Margin="0,-8,0,4"/>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Category"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource PrimaryBrush}"/>
                        <Border Background="{ThemeResource CardBackgroundBrush}"
                                BorderBrush="{ThemeResource PrimaryBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,2">
                            <ComboBox x:Name="CategoryComboBox"
                                      PlaceholderText="Select category"
                                      MinWidth="300"
                                      MinHeight="44"
                                      Background="Transparent"
                                      RequestedTheme="Light"
                                      Foreground="{ThemeResource DeepTextBrush}"
                                      BorderThickness="0">
                                <ComboBoxItem Content="CheckIn"/>
                                <ComboBoxItem Content="Parking"/>
                                <ComboBoxItem Content="Baggage"/>
                                <ComboBoxItem Content="Tickets"/>
                                <ComboBoxItem Content="Facilities"/>
                               
                            </ComboBox>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Question"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource PrimaryBrush}"/>
                        <Border Background="{ThemeResource CardBackgroundBrush}"
                                BorderBrush="{ThemeResource PrimaryBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,6">
                            <TextBox x:Name="QuestionTextBox"
                                     PlaceholderText="Enter the question"
                                     TextWrapping="Wrap"
                                     MinWidth="300"
                                     MinHeight="44"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{ThemeResource DeepTextBrush}">
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlForeground" Color="{ThemeResource DeepTextColor}"/>
                                    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{ThemeResource DeepTextColor}"/>
                                    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="{ThemeResource DeepTextColor}"/>
                                    <SolidColorBrush x:Key="TextControlForegroundDisabled" Color="{ThemeResource SecondaryTextColor}"/>
                                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="{ThemeResource SecondaryTextColor}"/>
                                </TextBox.Resources>
                            </TextBox>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Answer"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource PrimaryBrush}"/>
                        <Border Background="{ThemeResource CardBackgroundBrush}"
                                BorderBrush="{ThemeResource PrimaryBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,6">
                            <TextBox x:Name="AnswerTextBox"
                                     PlaceholderText="Enter the answer"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinWidth="300"
                                     Height="140"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{ThemeResource DeepTextBrush}">
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="Transparent"/>
                                    <SolidColorBrush x:Key="TextControlForeground" Color="{ThemeResource DeepTextColor}"/>
                                    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{ThemeResource DeepTextColor}"/>
                                    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="{ThemeResource DeepTextColor}"/>
                                    <SolidColorBrush x:Key="TextControlForegroundDisabled" Color="{ThemeResource SecondaryTextColor}"/>
                                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="{ThemeResource SecondaryTextColor}"/>
                                </TextBox.Resources>
                            </TextBox>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="10"
                                Margin="0,8,0,0">

                        <Button x:Name="CancelButton"
                                Content="Cancel"
                                Click="CancelButton_Click"
                                Background="{ThemeResource CardBackgroundBrush}"
                                Foreground="{ThemeResource PrimaryBrush}"
                                BorderBrush="{ThemeResource PrimaryBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18,10">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="{ThemeResource CardBackgroundColor}"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#D6F1F4"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#C4E8ED"/>
                                <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#F3F4F6"/>
                                <SolidColorBrush x:Key="ButtonForeground" Color="{ThemeResource PrimaryColor}"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{ThemeResource PrimaryColor}"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#1F5B70"/>
                                <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="{ThemeResource SecondaryTextColor}"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush" Color="{ThemeResource PrimaryBorderColor}"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{ThemeResource PrimaryBorderColor}"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#8FD2DA"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="{ThemeResource CardBackgroundColor}"/>
                            </Button.Resources>
                        </Button>

                        <Button x:Name="SaveButton"
                                Content="Save Changes"
                                Click="SaveButton_Click"
                                Background="{ThemeResource PrimaryVariantBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                CornerRadius="8"
                                Padding="18,10">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="{ThemeResource PrimaryVariantColor}"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#25B8C0"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#1FA7AF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="{ThemeResource PrimaryBorderColor}"/>
                                <SolidColorBrush x:Key="ButtonForeground" Color="White"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                                <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="{ThemeResource CardBackgroundColor}"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush" Color="{ThemeResource PrimaryVariantColor}"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#25B8C0"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#1FA7AF"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="{ThemeResource PrimaryBorderColor}"/>
                            </Button.Resources>
                        </Button>

                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>