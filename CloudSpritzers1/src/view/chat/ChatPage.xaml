<Page
    x:Class="CloudSpritzers1.Src.View.Chat.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:msg="using:CloudSpritzers1.Src.Model.Message"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="using:CloudSpritzers1.Src.View.Message"
    xmlns:dto="using:CloudSpritzers1.Src.Dto"
    xmlns:local="using:CloudSpritzers1.Src.View.Chat"
    xmlns:bot="using:CloudSpritzers1.Src.Model.Faq.Bot"
    x:Name="RootPage"
    mc:Ignorable="d"
    Background="{ThemeResource CardBackgroundBrush}">

    <Grid Padding="20">

		<!-- ROWS -->
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,20">

            <Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<Grid Width="40" Height="40">
                <Ellipse Fill="{ThemeResource PrimaryBrush}"/>
				<FontIcon Glyph="&#xE8BD;"
                          Foreground="White"
                          FontSize="18"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
			</Grid>

            <StackPanel Grid.Column="1"
            Margin="15,0,0,0"
            VerticalAlignment="Center">

                <TextBlock Text="Chat Support"
               Foreground="{ThemeResource PrimaryTextBrush}" 
               FontSize="18"
               FontWeight="SemiBold"/>

                <TextBlock Text="{x:Bind ViewModel.FormatUserId}"
               Foreground="{ThemeResource SecondaryTextBrush}" 
               FontSize="12"/>
            </StackPanel>

            <Button Grid.Column="2"
                    Click="EndChat"
                             Content="End Chat"
                             Background="{ThemeResource PrimaryBrush}"
                             Foreground="White"
                             CornerRadius="6"
                             VerticalAlignment="Center">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackground" Color="{StaticResource PrimaryColor}"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource PrimaryLightColor}"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource PrimaryMutedColor}"/>
                    <SolidColorBrush x:Key="ButtonBackgroundFocused" Color="{StaticResource PrimaryColor}"/>
                    <SolidColorBrush x:Key="ButtonForeground" Color="{StaticResource CardBackgroundColor}"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource CardBackgroundColor}"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource CardBackgroundColor}"/>
                    <SolidColorBrush x:Key="ButtonForegroundFocused" Color="{StaticResource CardBackgroundColor}"/>
                </Button.Resources>
            </Button>
		</Grid>

		<!-- SEPARATOR -->
		<Border Grid.Row="0"
                Height="1"
                Background="{ThemeResource BorderBrush}"
                VerticalAlignment="Bottom"
                Margin="-20,10,-20,0"/>

		<!-- CHAT AREA -->
        <ListView Grid.Row="1" 
          ItemsSource="{x:Bind ViewModel.ChatHistory, Mode=OneWay}"
          SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="dto:MessageDTO">
                    <view:MessageView Margin="0,5" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- OPTIONS -->
        <StackPanel Grid.Row="2"
            Spacing="10"
            Margin="0,10,0,10">

            <TextBlock Text="Please select an option:"
               Foreground="{ThemeResource SecondaryTextBrush}"
               FontSize="13"/>

            <StackPanel Orientation="Horizontal"
                Spacing="8">

                <StackPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="{ThemeResource PrimaryBrush}"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter x:Name="ContentPresenter"
                                Background="{TemplateBinding Background}"
                                Foreground="{TemplateBinding Foreground}"
                                Content="{TemplateBinding Content}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroup x:Name="CommonStates">
                                                <VisualState x:Name="Normal" />
                                                <VisualState x:Name="PointerOver">
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                                Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)"
                                                                To="{ThemeResource PrimaryLightColor}" Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </VisualState>
                                                <VisualState x:Name="Pressed">
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                                Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)"
                                                                To="{ThemeResource PrimaryMutedColor}" Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateManager.VisualStateGroups>
                                    </ContentPresenter>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </StackPanel.Resources>

                <ItemsControl ItemsSource="{x:Bind ViewModel.CurrentOptions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" 
                           MaximumRowsOrColumns="-1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="bot:FAQOption">
                            <Button Content="{x:Bind label}" 
                    Margin="4"
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center" 
                    VerticalContentAlignment="Center"
                    Width="200"
                    Command="{Binding ElementName=RootPage, Path=ViewModel.HandleOptionClickCommand}"
                    CommandParameter="{x:Bind}">
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </StackPanel>

    </Grid>

</Page>
