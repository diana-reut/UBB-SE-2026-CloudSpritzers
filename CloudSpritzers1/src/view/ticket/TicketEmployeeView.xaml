<?xml version="1.0" encoding="utf-8"?>
<Page
   x:Class="CloudSpritzers1.Src.View.Ticket.TicketEmployeeView"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   xmlns:controls="using:Microsoft.UI.Xaml.Controls" 
   xmlns:ticket="using:CloudSpritzers1.Src.Model.Ticket"
   xmlns:general="using:CloudSpritzers1.Src.View.General"
   xmlns:dto ="using:CloudSpritzers1.Src.Dto"
   RequestedTheme="Light"
   Background="{ThemeResource PageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="TicketButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{ThemeResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Root"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="{ThemeResource PrimaryLightColor}"
                                Duration="0:0:0"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Root"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="{ThemeResource PrimaryMutedColor}"
                                Duration="0:0:0"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <general:UpperBar Grid.Row="0" />

        <Grid Grid.Row="1" Padding="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,24">
                <StackPanel Spacing="24">

                    <!-- HEADER -->
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Border Width="60" Height="60" CornerRadius="8" Background="{ThemeResource PrimaryBrush}">
                            <Grid>
                                <Path Fill="White" Stretch="Uniform" Width="34" Height="34"
                                  Data="M4,10 A2,2 0 0 1 6,8 H26 A2,2 0 0 1 28,10 V14 A2,2 0 0 0 28,18 V22 A2,2 0 0 1 26,24 H6 A2,2 0 0 1 4,22 V18 A2,2 0 0 0 4,14 Z"/>
                                <Line X1="18" Y1="16" X2="18" Y2="44" Stroke="{ThemeResource PrimaryLightBrush}" StrokeThickness="2" StrokeDashArray="2,2"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <StackPanel>
                            <TextBlock Text="Support Tickets" FontSize="28" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                            <TextBlock Width="600" TextWrapping="Wrap" Foreground="{ThemeResource SecondaryTextBrush}"
                                   Text="Resolve the requests of our customers."/>
                        </StackPanel>
                    </StackPanel>

                    <!-- TICKETS BOX -->
                    <Border Background="{ThemeResource CardBackgroundBrush}" CornerRadius="8" Padding="32" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Vertical" Spacing="4">
                                <TextBlock Text="Tickets" FontSize="28" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                                <TextBlock Text="Change the status of submitted tickets." FontSize="14" Foreground="{ThemeResource SecondaryTextBrush}"/>
                            </StackPanel>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="180"/>
                                    </Grid.ColumnDefinitions>
                                    <SymbolIcon Symbol="Filter" Foreground="{ThemeResource SecondaryTextBrush}" VerticalAlignment="Center" Width="24" Height="24" Margin="0,0,8,0"/>
                                    <ComboBox Grid.Column="1" Width="180" Background="{ThemeResource BorderBrush}" Foreground="{ThemeResource PrimaryTextBrush}" PlaceholderText="Filter tickets" SelectedIndex="0" SelectionChanged="FilterChanged">
                                        <ComboBoxItem Content="All Tickets" Tag="ALL"/>
                                        <ComboBoxItem Content="Open" Tag="OPEN"/>
                                        <ComboBoxItem Content="In Progress" Tag="IN_PROGRESS"/>
                                        <ComboBoxItem Content="Resolved" Tag="RESOLVED"/>
                                    </ComboBox>
                                </Grid>
                            </Grid>

                            <ItemsControl Grid.Row="1" x:Name="TicketList" ItemsSource="{x:Bind ViewModel.FilteredTicketsForDisplay, Mode=OneWay}" Margin="0,24,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="dto:TicketDTO">
                                        <Border Background="{ThemeResource CardBackgroundBrush}" 
                    BorderBrush="{ThemeResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="20" 
                    Margin="0,0,0,16">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="{x:Bind ticketId}" FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}"/>
                                                    <TextBlock Text="{x:Bind subject}" FontSize="18" FontWeight="Bold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                                                    <TextBlock Text="{x:Bind description}" Foreground="{ThemeResource SecondaryTextBrush}" Margin="0,4,0,8"/>

                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <TextBlock Text="{Binding categoryName, ConverterParameter='Category: {0}', Mode=OneWay}" FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}"/>
                                                        <TextBlock Text="|" Foreground="{ThemeResource SecondaryTextBrush}"/>
                                                        <TextBlock Text= "{x:Bind subcategoryName}" FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}"/>
                                                        <TextBlock Text="|" Foreground="{ThemeResource SecondaryTextBrush}"/>
                                                        <TextBlock Text= "{x:Bind creationTimestamp}" FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}"/>
                                                        <TextBlock Text="|" Foreground="{ThemeResource SecondaryTextBrush}"/>
                                                        <TextBlock Text="{x:Bind creatorEmailAddress}" FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Spacing="8">
                                                    <Border Background="#eef2ff" Padding="8,4" CornerRadius="4">
                                                        <TextBlock Text="{x:Bind currentStatus}" Foreground="#4f46e5" FontSize="12" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <Border Background="#fef2f2" Padding="8,4" CornerRadius="4">
                                                        <TextBlock Text="{x:Bind urgencyLevel}" Foreground="#ef4444" FontSize="12" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <Button Content="Update Status" 
                                Click="EditTicketStatus_Click" 
                                Tag="{x:Bind ticketId}"
                                Style="{StaticResource TicketButtonStyle}"
                                Padding="12,4"
                                Margin="10,0,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#fff4e5" CornerRadius="8" Padding="12" Height="70">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <SymbolIcon Symbol="Clock" Foreground="#ffb347" VerticalAlignment="Top" Margin="0,2,0,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Open" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource PrimaryTextBrush}"/>
                            <TextBlock Text="Awaiting review" FontSize="11" Foreground="{ThemeResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#e5f0ff" CornerRadius="8" Padding="12" Height="70">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <SymbolIcon Symbol="Sync" Foreground="#5ca0ff" VerticalAlignment="Top" Margin="0,2,0,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="In Progress" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource PrimaryTextBrush}"/>
                            <TextBlock Text="Under investigation" FontSize="11" Foreground="{ThemeResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#e6ffed" CornerRadius="8" Padding="12" Height="70">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <SymbolIcon Symbol="Accept" Foreground="#22c55e" VerticalAlignment="Top" Margin="0,2,0,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Resolved" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource PrimaryTextBrush}"/>
                            <TextBlock Text="Issue closed" FontSize="11" Foreground="{ThemeResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
