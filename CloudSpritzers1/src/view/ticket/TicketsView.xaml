<Page
    x:Class="CloudSpritzers1.Src.View.Ticket.TicketsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:dto="using:CloudSpritzers1.Src.Dto"
    xmlns:general="using:CloudSpritzers1.Src.View.General"
    RequestedTheme="Light"
    Background="{ThemeResource PageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="TicketButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{ThemeResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="6">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Root"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="{ThemeResource PrimaryLightColor}" Duration="0:0:0"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Root"
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="{ThemeResource PrimaryMutedColor}" Duration="0:0:0"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <general:UpperBar Grid.Row="0" />

        <Grid Grid.Row="1">

            <Grid Padding="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="24">

                        <!-- HEADER -->
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <Border Width="60" Height="60" CornerRadius="8" Background="{ThemeResource PrimaryBrush}">
                                <Grid>
                                    <Path Fill="White" Stretch="Uniform" Width="34" Height="34"
                                  Data="M4,10 A2,2 0 0 1 6,8 H26 A2,2 0 0 1 28,10 V14 A2,2 0 0 0 28,18 V22 A2,2 0 0 1 26,24 H6 A2,2 0 0 1 4,22 V18 A2,2 0 0 0 4,14 Z"/>
                                    <Line X1="18" Y1="16" X2="18" Y2="44" Stroke="{ThemeResource PrimaryLightBrush}" StrokeThickness="2" StrokeDashArray="2,2"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <StackPanel>
                                <TextBlock Text="Support Tickets" FontSize="28" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                                <TextBlock Width="600" TextWrapping="Wrap" Foreground="{ThemeResource SecondaryTextBrush}"
                                   Text="Submit and track your support requests. We make sure everyone knows you're complaining."/>
                            </StackPanel>
                        </StackPanel>

                        <!-- CREATE BUTTON -->
                        <Button x:Name="CreateTicketButton" Content="Create new ticket" Width="180" Height="40"
                        Style="{StaticResource TicketButtonStyle}" Click="CreateTicketButton_Click"/>

                        <!-- WHITE BOX FOR TICKETS -->
                        <Border Background="{ThemeResource CardBackgroundBrush}" CornerRadius="8" Padding="32" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                        Width="Auto" Height="Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Vertical" Spacing="4">
                                        <TextBlock Text="Tickets" FontSize="28" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                                        <TextBlock Text="Track the status of your submitted tickets" FontSize="14" Foreground="{ThemeResource SecondaryTextBrush}"/>
                                    </StackPanel>

                                    <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>
                                        <SymbolIcon Symbol="Filter" Foreground="{ThemeResource SecondaryTextBrush}" VerticalAlignment="Center" Width="24" Height="24" Margin="0,0,8,0"/>
                                        <ComboBox Grid.Column="1" Width="180" Background="{ThemeResource BorderBrush}" Foreground="{ThemeResource PrimaryTextBrush}" PlaceholderText="Filter tickets"
                                          SelectedIndex="0" SelectionChanged="FilterChanged">
                                            <ComboBoxItem Content="All Tickets" Tag="ALL"/>
                                            <ComboBoxItem Content="Open" Tag="OPEN"/>
                                            <ComboBoxItem Content="In Progress" Tag="IN_PROGRESS"/>
                                            <ComboBoxItem Content="Resolved" Tag="RESOLVED"/>
                                        </ComboBox>
                                    </Grid>
                                </Grid>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,24,0,0">
                                    <ItemsControl x:Name="TicketList" ItemsSource="{x:Bind ViewModel.FilteredTicketsForDisplay, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="dto:TicketDTO">
                                                <Border Background="{ThemeResource CardBackgroundBrush}" CornerRadius="8" Padding="16" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" Margin="0,0,0,16">
                                                    <StackPanel Spacing="16">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="{x:Bind ticketId}" FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                                <Border CornerRadius="4" Padding="6,2" Background="#dbeafe">
                                                                    <TextBlock Text="{x:Bind currentStatus}" FontSize="12" Foreground="#383cb8"/>
                                                                </Border>
                                                                <Border CornerRadius="4" Padding="6,2" Background="#ffe2e2">
                                                                    <TextBlock Text="{x:Bind urgencyLevel}" FontSize="12" Foreground="#aa161e"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </Grid>

                                                        <TextBlock Text="{x:Bind subject}" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                                                        <TextBlock Text="{x:Bind description}" FontSize="14" Foreground="{ThemeResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                                                        <TextBlock FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}" TextWrapping="Wrap">
                                                    <Run Text="Category: "/><Run Text="{x:Bind categoryName}"/>
                                                    <Run Text=" | Subcategory: "/><Run Text="{x:Bind subcategoryName}"/>
                                                    <Run Text=" | Created: "/><Run Text="{x:Bind creationTimestamp}"/>
                                                    <Run Text=" | Email: "/><Run Text="{x:Bind creatorEmailAddress}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- STATUS LEGEND -->
                <Grid Grid.Row="1" Margin="0,24,0,0" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#fff4e5" CornerRadius="8" Padding="16">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <SymbolIcon Symbol="Clock" Foreground="#ffb347"/>
                            <StackPanel>
                                <TextBlock Text="Open" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                                <TextBlock Text="Your ticket has been received and is awaiting review" FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#e5f0ff" CornerRadius="8" Padding="16">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <SymbolIcon Symbol="Sync" Foreground="#5ca0ff"/>
                            <StackPanel>
                                <TextBlock Text="In Progress" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                                <TextBlock Text="An employee is currently investigating or resolving your issue" FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#e6ffed" CornerRadius="8" Padding="16">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <SymbolIcon Symbol="Accept" Foreground="#22c55e"/>
                            <StackPanel>
                                <TextBlock Text="Resolved" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                                <TextBlock Text="Your issue has been addressed and the ticket is closed" FontSize="12" Foreground="{ThemeResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
